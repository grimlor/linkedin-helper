{
  "manifest_version": 3,
  "name": "LinkedIn Skills Bulk Delete",
  "version": "0.1.0",
  "description": "Bulk-delete skills from your LinkedIn profile",

  "permissions": ["storage"],

  "host_permissions": [
    "https://www.linkedin.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "all_frames": true,
      "world": "MAIN",
      "js": ["dist/content.js"],
      "run_at": "document_end"
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

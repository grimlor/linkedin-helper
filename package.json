{
  "name": "linkedin-helper",
  "version": "0.1.0",
  "type": "module",
  "description": "Edge browser extension for bulk-deleting LinkedIn skills",
  "scripts": {
    "build": "esbuild src/content.ts --bundle --format=iife --outfile=dist/content.js --target=es2020",
    "build:watch": "esbuild src/content.ts --bundle --format=iife --outfile=dist/content.js --target=es2020 --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": ["eslint --fix"]
  },
  "keywords": ["linkedin", "edge-extension", "chromium", "browser-extension", "skills"],
  "author": "Jack Pines",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.278",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.3.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
